CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

REDIS_DB=0          # default Redis database (dipakai cache)
REDIS_CACHE_DB=0    # Redis DB untuk cache (bisa sama dengan default)
REDIS_SESSION_DB=2 # Redis DB untuk session (bisa 1 atau lainnya)
SESSION_CONNECTION=session

CACHE_PREFIX=hafid_course_cache_
REDIS_PREFIX=

SESSION_PREFIX=hafid_course_session_

SESSION_COOKIE=hafid_course_session
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=YOUR-MAILTRAP-USERNAME
MAIL_PASSWORD=YOUR-MAILTRAP-PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="test@hafidtech.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_QUEUE=true

GOOGLE_CLIENT_ID=YOUR-GOOGLE-CLIENT-ID
GOOGLE_CLIENT_SECRET=YOUR-GOOGLE-CLIENT-SECRET
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/oauth/google/callback

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=YOUR-PAYPAL-SANDBOX-CLIENT-ID
PAYPAL_SANDBOX_CLIENT_SECRET=YOUR-PAYPAL-SANDBOX-CLIENT-SECRET
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=
PAYPAL_LIVE_APP_ID=
PAYPAL_PAYMENT_ACTION=Sale
PAYPAL_CURRENCY=USD
PAYPAL_VALIDATE_SSL=false

MIDTRANS_SERVER_KEY=YOUR-MIDTRANS-SERVERK-EY
MIDTRANS_CLIENT_KEY=YOUR-MIDTRANS-CLIENT-KEY
MIDTRANS_IS_PRODUCTION=false

SANCTUM_STATEFUL_DOMAINS=
